
HOST=0.0.0.0
PORT=3000

REACT_APP_GOOGLE_CLIENT_ID=367092673366-78kvueautamcsailo3n6a3cfulr3091r.apps.googleusercontent.com
# Google Maps Embed API (para ver mapas dentro del sistema)
# Crea una API Key en Google Cloud y habilita "Maps Embed API".
REACT_APP_GOOGLE_MAPS_EMBED_API_KEY=
# Opcional: Google Geocoding API (para convertir dirección -> lat/lng con un botón "Buscar dirección")
# Puedes usar la misma key si también habilitas "Geocoding API".
REACT_APP_GOOGLE_MAPS_GEOCODING_API_KEY=

# Si usas ngrok/https para el frontend, pon aquí la URL pública (ej: https://xxxx.ngrok-free.app)
# Esto permite usar back_urls en Mercado Pago y que vuelva a /checkout/resultado.
REACT_APP_MP_BACK_URL_BASE=
# Déjalo vacío si el backend corre en la misma PC que expone el frontend por red local.
# El frontend detectará automáticamente la IP/host actual y usará el puerto 8083.
REACT_APP_API_URL=
